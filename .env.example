# Copy this file to .env and fill in real values. Never commit .env.
NODE_ENV=development
LOG_LEVEL=info
TIMEZONE=America/Bogota

# Matches docker-compose.yml defaults. Change the password before any
# real/shared deployment.
POSTGRES_USER=job_radar
POSTGRES_PASSWORD=job_radar
POSTGRES_DB=job_radar
DATABASE_URL=postgres://job_radar:job_radar@localhost:5432/job_radar

